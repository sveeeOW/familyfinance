// Family Finance — Prisma schema
// Реализует модель данных из раздела 18 ТЗ + вспомогательные таблицы:
// refresh-токены, токены привязки Telegram, бюджеты/лимиты (§16),
// доли распределения расходов (§22), правила автокатегоризации (§11.4), аудит изменений.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────────────────────────────────────

enum PortfolioType {
  PERSONAL // личный
  FAMILY // семейный
  SHARED // совместный
  INVESTMENT // инвестиционный
  GOAL // целевой
  OTHER // другой
}

enum MemberRole {
  OWNER // владелец портфеля
  MEMBER // участник
  VIEWER // только просмотр
}

// Уровни доступа из §6.3
enum AccessLevel {
  FULL // полный доступ
  LIMITED // ограниченный доступ
  VIEW_ONLY // только просмотр
  PRIVATE // личный режим (часть расходов скрыта)
}

enum MemberStatus {
  ACTIVE
  INVITED
  REMOVED
}

enum InviteStatus {
  ACTIVE
  EXPIRED
  REVOKED
}

enum IncomeType {
  SALARY // зарплата
  ADVANCE // аванс
  BONUS // премия
  DIVIDENDS // дивиденды
  INVESTMENT // инвестиционный доход
  DEPOSIT_INTEREST // проценты по вкладам
  DEBT_RETURN // возврат долга
  GIFT // подарок
  SIDE_JOB // подработка
  OTHER // иной доход
}

enum Recurrence {
  MONTHLY // ежемесячно
  TWICE_A_MONTH // два раза в месяц
  WEEKLY // еженедельно
  ONE_TIME // разово
  CUSTOM // произвольный график
}

// Тип расхода: личный / общий (§8.4)
enum ExpenseScope {
  PERSONAL
  SHARED
}

// Источник расхода (§18.6 поле source)
enum ExpenseSource {
  MANUAL // вручную
  TELEGRAM_BOT // через Telegram-бота
  MOBILE_OCR // скан в приложении
  IMPORT // импорт
  RECURRING // сгенерирован регулярным платежом
}

// Статусы AI-обработки (§11.2) + общий жизненный цикл расхода
enum ExpenseStatus {
  CONFIRMED // распознан и подтверждён / добавлен вручную
  PENDING // распознан, ожидает подтверждения
  NEEDS_CLARIFICATION // требует уточнения
  RECOGNITION_ERROR // ошибка распознавания
}

// Способ распределения общего расхода (§22)
enum SplitType {
  NONE // без распределения
  EQUAL // поровну
  PERCENT // по процентам
  SHARES // произвольные доли / "один оплатил, остальные компенсируют"
}

enum AssetType {
  STOCK // акция
  BOND // облигация
  FUND // фонд
  DEPOSIT // вклад
  CRYPTO // криптовалюта
  OTHER // другое
}

enum DividendStatus {
  EXPECTED // ожидается
  RECEIVED // получено
  CANCELED // отменено
}

enum CreditStatus {
  ACTIVE
  CLOSED
  OVERDUE
}

enum BudgetScope {
  PORTFOLIO // общий месячный лимит портфеля
  CATEGORY // лимит по категории
  MEMBER // лимит по участнику
}

enum AiStatus {
  CONFIRMED
  PENDING
  NEEDS_CLARIFICATION
  ERROR
}

// ─────────────────────────────────────────────────────────────────────────────
// Users & auth (§18.1, §5)
// ─────────────────────────────────────────────────────────────────────────────

model User {
  id              String   @id @default(uuid())
  name            String
  email           String?  @unique
  phone           String?  @unique
  passwordHash    String   @map("password_hash")
  telegramId      String?  @unique @map("telegram_id")
  avatarUrl       String?  @map("avatar_url")
  defaultCurrency String   @default("RUB") @map("default_currency")
  timezone        String   @default("Europe/Moscow")
  locale          String   @default("ru")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  ownedPortfolios   Portfolio[]        @relation("PortfolioOwner")
  memberships       PortfolioMember[]
  createdInvites    InviteLink[]       @relation("InviteCreator")
  incomes           Income[]
  expenses          Expense[]          @relation("ExpenseUser")
  paidExpenses      Expense[]          @relation("ExpensePayer")
  expenseShares     ExpenseShare[]
  recurringPayments RecurringPayment[]
  credits           Credit[]
  investments       Investment[]
  dividends         Dividend[]
  refreshTokens     RefreshToken[]
  telegramLinks     TelegramLinkToken[]
  deviceTokens      DeviceToken[]
  categoryRules     CategoryRule[]
  resetTokens       PasswordResetToken[]
  budgets           Budget[]

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  tokenHash String   @map("token_hash")
  expiresAt DateTime @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  tokenHash String   @unique @map("token_hash")
  expiresAt DateTime @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("password_reset_tokens")
}

// Push-устройства
model DeviceToken {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  token     String   @unique
  platform  String
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("device_tokens")
}

// Код привязки Telegram-аккаунта (§10.2)
model TelegramLinkToken {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  code      String   @unique
  expiresAt DateTime @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("telegram_link_tokens")
}

// ─────────────────────────────────────────────────────────────────────────────
// Portfolios & membership (§18.2–18.4, §6)
// ─────────────────────────────────────────────────────────────────────────────

model Portfolio {
  id             String        @id @default(uuid())
  name           String
  type           PortfolioType @default(PERSONAL)
  ownerUserId    String        @map("owner_user_id")
  currency       String        @default("RUB")
  description    String?
  currentBalance Decimal       @default(0) @map("current_balance") @db.Decimal(18, 2)
  isDefault      Boolean       @default(false) @map("is_default")
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  owner             User               @relation("PortfolioOwner", fields: [ownerUserId], references: [id])
  members           PortfolioMember[]
  invites           InviteLink[]
  incomes           Income[]
  expenses          Expense[]
  categories        Category[]
  recurringPayments RecurringPayment[]
  credits           Credit[]
  investments       Investment[]
  dividends         Dividend[]
  budgets           Budget[]

  @@index([ownerUserId])
  @@map("portfolios")
}

model PortfolioMember {
  id          String       @id @default(uuid())
  portfolioId String       @map("portfolio_id")
  userId      String       @map("user_id")
  role        MemberRole   @default(MEMBER)
  accessLevel AccessLevel  @default(FULL) @map("access_level")
  status      MemberStatus @default(ACTIVE)
  joinedAt    DateTime     @default(now()) @map("joined_at")

  portfolio Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([portfolioId, userId])
  @@index([userId])
  @@map("portfolio_members")
}

model InviteLink {
  id              String       @id @default(uuid())
  portfolioId     String       @map("portfolio_id")
  createdByUserId String       @map("created_by_user_id")
  token           String       @unique @map("invite_token")
  role            MemberRole   @default(MEMBER)
  accessLevel     AccessLevel  @default(FULL) @map("access_level")
  expiresAt       DateTime?    @map("expires_at")
  maxUses         Int          @default(1) @map("max_uses")
  usedCount       Int          @default(0) @map("used_count")
  status          InviteStatus @default(ACTIVE)
  createdAt       DateTime     @default(now())

  portfolio Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  createdBy User      @relation("InviteCreator", fields: [createdByUserId], references: [id])

  @@index([portfolioId])
  @@map("invite_links")
}

// ─────────────────────────────────────────────────────────────────────────────
// Income (§18.5, §7)
// ─────────────────────────────────────────────────────────────────────────────

model Income {
  id           String     @id @default(uuid())
  portfolioId  String     @map("portfolio_id")
  userId       String     @map("user_id")
  type         IncomeType @default(SALARY)
  amount       Decimal    @db.Decimal(18, 2)
  currency     String     @default("RUB")
  date         DateTime
  recurrence   Recurrence @default(MONTHLY) @map("recurrence_type")
  paymentDay   Int?       @map("payment_day") // число месяца для регулярного дохода
  description  String?
  isForecast   Boolean    @default(false) @map("is_forecast")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  portfolio Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([portfolioId])
  @@index([userId])
  @@map("incomes")
}

// ─────────────────────────────────────────────────────────────────────────────
// Expenses & splits (§18.6, §8, §22)
// ─────────────────────────────────────────────────────────────────────────────

model Expense {
  id            String        @id @default(uuid())
  portfolioId   String        @map("portfolio_id")
  userId        String        @map("user_id") // кто внёс запись
  paidByUserId  String        @map("paid_by_user_id") // кто фактически оплатил
  categoryId    String?       @map("category_id")
  amount        Decimal       @db.Decimal(18, 2)
  currency      String        @default("RUB")
  date          DateTime
  title         String?
  description   String?
  merchant      String?
  source        ExpenseSource @default(MANUAL)
  scope         ExpenseScope  @default(SHARED) @map("scope")
  splitType     SplitType     @default(NONE) @map("split_type")
  status        ExpenseStatus @default(CONFIRMED)
  aiConfidence  Int?          @map("ai_confidence")
  screenshotUrl String?       @map("screenshot_url")
  paymentMethod String?       @map("payment_method")
  comment       String?
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  portfolio Portfolio      @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  user      User           @relation("ExpenseUser", fields: [userId], references: [id])
  paidBy    User           @relation("ExpensePayer", fields: [paidByUserId], references: [id])
  category  Category?      @relation(fields: [categoryId], references: [id])
  shares    ExpenseShare[]

  @@index([portfolioId])
  @@index([paidByUserId])
  @@index([date])
  @@map("expenses")
}

model ExpenseShare {
  id        String   @id @default(uuid())
  expenseId String   @map("expense_id")
  userId    String   @map("user_id")
  amount    Decimal  @db.Decimal(18, 2)
  percent   Decimal? @db.Decimal(5, 2)

  expense Expense @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id])

  @@index([expenseId])
  @@index([userId])
  @@map("expense_shares")
}

