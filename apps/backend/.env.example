# ─── Database ───────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://familyfinance:familyfinance@localhost:5432/familyfinance?schema=public"

# ─── Server ─────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
# Базовый публичный URL backend (для invite-ссылок и Telegram webhook)
PUBLIC_URL=http://localhost:3000
# CORS: список origin'ов через запятую (* для dev)
CORS_ORIGINS=*

# ─── JWT ────────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_TTL=900            # сек (15 мин)
JWT_REFRESH_TTL=2592000       # сек (30 дней)

# ─── AI / распознавание чеков ────────────────────────────────────────────────
# Провайдер: claude | mock  (mock — без внешних вызовов, для разработки/тестов)
AI_PROVIDER=claude
ANTHROPIC_API_KEY=sk-ant-xxxxx
AI_MODEL=claude-sonnet-4-6
AI_MAX_TOKENS=1024

# ─── Очереди (BullMQ / Redis) ────────────────────────────────────────────────
# Пусто = распознавание чеков выполняется инлайн (без очереди). Задайте для async-обработки.
REDIS_URL=

# ─── Email (SMTP) ────────────────────────────────────────────────────────────
# Пусто = письма выводятся в лог (console-драйвер). Для реальной отправки заполните SMTP.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM=Family Finance <no-reply@familyfinance.app>

# ─── Push-уведомления (Expo) ─────────────────────────────────────────────────
# Необязательно; нужен только для расширенных лимитов Expo Push.
EXPO_ACCESS_TOKEN=

# ─── Telegram-бот ────────────────────────────────────────────────────────────
# Пусто = бот выключен. В dev используется long polling.
TELEGRAM_BOT_TOKEN=
# Для prod-режима webhook задайте TELEGRAM_WEBHOOK_DOMAIN (https), иначе long polling.
TELEGRAM_WEBHOOK_DOMAIN=

# ─── Хранилище файлов ────────────────────────────────────────────────────────
# Драйвер: local | s3
STORAGE_DRIVER=local
STORAGE_LOCAL_DIR=./uploads
# S3 (если STORAGE_DRIVER=s3)
S3_ENDPOINT=
S3_REGION=ru-central1
S3_BUCKET=familyfinance
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_PUBLIC_URL=
